# Example environment variables for clr-jira-studio
# Copy this file to .env and edit values before running locally or in CI.

JIRA_BASE_URL=http://localhost:8080
JIRA_PAT=your-jira-personal-access-token-here
JIRA_DEFAULT_USER=your-default-jira-username
JIRA_ADMIN_USER=your-jira-admin-username
JIRA_ADMIN_PASSWORD=your-jira-admin-password
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

POSTGRES_PASSWORD=your-postgres-password
ATL_JDBC_PASSWORD=your-postgres-password

# Do not commit your real .env file; keep secrets out of the repo.